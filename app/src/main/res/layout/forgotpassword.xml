<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    android:orientation="vertical"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".LoginActivity2"
    android:layout_gravity="center"
    android:background="@drawable/bgimage2">

    <ImageView
        android:layout_width="130dp"
        android:layout_height="130dp"
        android:src="@drawable/logo"
        android:id="@+id/logo"
        android:layout_gravity="center"
        android:layout_marginTop="100dp"
        />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:id="@+id/tvSplashTitle"
        android:fontFamily="@font/agbalumo"
        android:text="Vaibhav Graphics"
        android:textColor="#0D47A1"
        android:textSize="20sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginRight="100dp"
        android:id="@+id/tvSplashSlogan"
        android:layout_marginBottom="30dp"
        android:layout_gravity="end"
        android:fontFamily="sans-serif-condensed-light"
        android:text=" Your Vision ,Our Design..!"
        android:textColor="#FF00FF"
        android:textSize="15sp"
        android:textStyle="bold"/>

    <androidx.cardview.widget.CardView
        android:layout_width="380dp"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="@android:color/transparent"
        app:cardCornerRadius="40dp"
        app:cardElevation="0dp"
        android:layout_gravity="center"
        android:layout_marginBottom="40dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:background="#80FFFFFF">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="15dp"
                android:fontFamily="@font/chonburi"
                android:gravity="center"
                android:text="Reset Your Password"
                android:textColor="#A9A9A9"
                android:textSize="24sp"
                android:textStyle="bold"
                />
            <com.google.android.material.textfield.TextInputEditText
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:id="@+id/etloginPassword"
                android:hint="Enter New Password"
                android:textColorHint="#757575"
                android:textColor="@color/black"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="15dp"
                android:padding="15dp"
                android:background="@drawable/input_shape"
                android:imeOptions="actionDone"
                android:inputType="textPassword"
                android:textSize="18sp"
                android:drawableLeft="@drawable/lockicon"
                android:drawablePadding="10dp"/>



            <com.google.android.material.textfield.TextInputEditText
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:id="@+id/etloginPassword"
                android:hint="Conform New Password"
                android:textColorHint="#757575"
                android:textColor="@color/black"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="15dp"
                android:padding="15dp"
                android:background="@drawable/input_shape"
                android:imeOptions="actionDone"
                android:inputType="textPassword"
                android:textSize="18sp"
                android:drawableLeft="@drawable/lockicon"
                android:drawablePadding="10dp"/>


            <Button
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_margin="15dp"
                android:layout_marginTop="10dp"
                android:backgroundTint="#bdbdbd"
                android:fontFamily="@font/chonburi"
                android:text="Continue"
                android:textColor="#454444"
                android:textSize="20sp"
                android:textStyle="bold"
                android:id="@+id/btnlogin"
                android:layout_marginBottom="22dp"/>

                android:textStyle="bold"/>


        </LinearLayout>
    </androidx.cardview.widget.CardView>
</LinearLayout>

