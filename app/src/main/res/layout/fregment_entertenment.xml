<?xml version="1.0" encoding="utf-8"?>

<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#F3F3F3">
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">
        <TextView
            android:id="@+id/tvEntertainmentSongName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Song Name :- Hamare Sath Shri Raghunath"
            android:textStyle="bold"
            android:textSize="22sp"
            android:textColor="#EF0D0D"
            android:gravity="center"
            android:layout_marginBottom="15dp"/>
        <androidx.cardview.widget.CardView
            android:layout_width="300dp"
            android:layout_height="300dp"
            android:layout_gravity="center"
            app:cardCornerRadius="18dp"
            app:cardElevation="8dp">
            <ImageView
                android:id="@+id/ivEntertenmentsongcoverpage"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@drawable/hamresath"
            android:scaleType="fitXY"/>
        </androidx.cardview.widget.CardView>
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="18dp">
            <TextView
                android:id="@+id/tvEntertenmentsongstarttime"
                android:layout_width="50dp"
                android:layout_height="wrap_content"
                android:text="00:00"
                android:textStyle="bold"
                android:textSize="15sp"/>
            <SeekBar
                android:id="@+id/sbEntertenmentSongProgress"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:progressTint="#FF1744"
                android:thumbTint="#FF1744"/>
            <TextView
                android:id="@+id/tvEntertenmentsongendtime"
                android:layout_width="50dp"
                android:layout_height="wrap_content"
                android:text="04:17"
                android:textStyle="bold"
                android:gravity="end"
                android:textSize="15sp"/>
        </LinearLayout>
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:gravity="center"
            android:orientation="horizontal">


            <ImageButton
                android:id="@+id/ibShuffle"
                android:layout_width="45dp"
                android:layout_height="45dp"
                android:layout_margin="4dp"
                android:background="@android:color/transparent"
                android:padding="8dp"
                android:src="@drawable/shuffle_icon"/>


            <ImageButton
                android:id="@+id/ibEntertenmentPreviousSong"
                android:layout_width="45dp"
                android:layout_height="45dp"
                android:layout_margin="4dp"
                android:background="@android:color/transparent"
                android:padding="8dp"
                android:src="@drawable/previousicon"/>


            <ImageButton
                android:id="@+id/ibEntertenmentBackwardSong"
                android:layout_width="45dp"
                android:layout_height="45dp"
                android:layout_margin="4dp"
                android:background="@android:color/transparent"
                android:padding="8dp"
                android:src="@drawable/backward_fast"/>


            <androidx.cardview.widget.CardView
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:layout_marginHorizontal="10dp"
                app:cardCornerRadius="36dp"
                app:cardElevation="8dp"
                app:cardBackgroundColor="#FF1744">

                <ImageButton
                    android:id="@+id/ibEntertainmentPlay"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@android:color/transparent"
                    android:padding="16dp"
                    android:src="@drawable/play_icon"/>

            </androidx.cardview.widget.CardView>


            <ImageButton
                android:id="@+id/ibEnertenmentForward"
                android:layout_width="45dp"
                android:layout_height="45dp"
                android:layout_margin="4dp"
                android:background="@android:color/transparent"
                android:padding="8dp"
                android:src="@drawable/forwardicon"/>


            <ImageButton
                android:id="@+id/ibEntertenmentNext"
                android:layout_width="45dp"
                android:layout_height="45dp"
                android:layout_margin="4dp"
                android:background="@android:color/transparent"
                android:padding="8dp"
                android:src="@drawable/nexticon"/>

        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Song List"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#212121"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="10dp"/>
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="250dp"
            android:layout_marginTop="8dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="6dp"
            app:cardBackgroundColor="#FFFFFF">

            <ListView
                android:id="@+id/listSongs"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:divider="#E0E0E0"
                android:dividerHeight="1dp"
                android:listSelector="?android:attr/selectableItemBackground"
                android:padding="8dp"
                android:scrollbars="vertical"/>

        </androidx.cardview.widget.CardView>

    </LinearLayout>

</ScrollView>