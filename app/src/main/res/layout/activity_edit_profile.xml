<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <androidx.cardview.widget.CardView
        android:layout_width="350dp"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        app:cardBackgroundColor="@color/white"
        app:cardCornerRadius="30dp"
        app:cardElevation="20dp"
        android:layout_marginLeft="30dp"
        android:id="@+id/setprofile">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="15dp"
                android:fontFamily="@font/chonburi"
                android:gravity="center"
                android:text="Fill The Information"
                android:textColor="#A9A9A9"
                android:textSize="24sp"
                android:textStyle="bold" />

            <ImageView
                android:layout_width="wrap_content"
                android:layout_height="130dp"
                android:src="@drawable/bgremovedprofileimage"
                android:id="@+id/editImgProfile"
                android:layout_gravity="center"></ImageView>
            <Button
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Choose Image"
                android:layout_gravity="center"
                android:backgroundTint="#bdbdbd"
                android:id="@+id/btnChooseImage"
                android:textStyle="bold">

            </Button>

            <EditText
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:id="@+id/etregistername"
                android:layout_marginTop="25dp"
                android:drawableLeft="@drawable/person_icon"
                android:drawablePadding="10dp"
                android:hint="Full Name"
                android:inputType="text"
                android:padding="15dp"
                android:textColor="@color/black"
                android:textColorHint="#666666" />

            <EditText
                android:id="@+id/etregisteremail"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:drawableLeft="@drawable/email_icon"
                android:drawablePadding="10dp"
                android:hint="Email Address"
                android:inputType="textEmailAddress"
                android:padding="15dp"
                android:textColor="@color/black"
                android:textColorHint="#666666" />
            <EditText
                android:id="@+id/editAddress"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:drawableLeft="@drawable/email_icon"
                android:drawablePadding="10dp"
                android:hint="Address"
                android:inputType="textEmailAddress"
                android:padding="15dp"
                android:textColor="@color/black"
                android:textColorHint="#666666" />
            <EditText
                android:id="@+id/etregisterphone"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:drawableLeft="@drawable/phone_icon"
                android:drawablePadding="10dp"
                android:hint="Phone Number"
                android:inputType="number"
                android:padding="15dp"
                android:textColor="@color/black"
                android:textColorHint="#666666" />

            <androidx.appcompat.widget.AppCompatButton
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:layout_margin="10dp"
                android:layout_gravity="center"
                android:id="@+id/btn_steprofile"
                android:layout_marginTop="10dp"
                android:text="Set Profile"
                android:textColor="#454444"
                android:textSize="20sp"
                android:textStyle="bold"
                android:backgroundTint="#bdbdbd"
                android:layout_marginBottom="20dp"/>

        </LinearLayout>
    </androidx.cardview.widget.CardView>

</LinearLayout>